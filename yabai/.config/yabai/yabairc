yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
sudo yabai --load-sa

yabai -m signal --add event=window_focused action="sketchybar --trigger yabai_refresh"
yabai -m signal --add event=window_created action="sketchybar --trigger yabai_refresh"
yabai -m signal --add event=window_destroyed action="sketchybar --trigger yabai_refresh"
yabai -m signal --add event=window_moved action="sketchybar --trigger yabai_refresh"
yabai -m signal --add event=application_front_switched action="sketchybar --trigger yabai_refresh"

yabai -m signal --add event=space_changed action="sketchybar --trigger yabai_refresh"
yabai -m signal --add event=space_created action="sketchybar --trigger yabai_refresh"
yabai -m signal --add event=space_destroyed action="sketchybar --trigger yabai_refresh"


yabai -m config layout bsp
yabai -m config window_placement second_child

yabai -m config top_padding    11
yabai -m config bottom_padding 11
yabai -m config left_padding   11
yabai -m config right_padding  62 # 12 + 51 
yabai -m config window_gap     12

yabai -m config split_ratio 0.5

yabai -m config mouse_modifier fn
yabai -m config mouse_action1 move
yabai -m config mouse_action2 resize

# set focus follows mouse mode (default: off, options: off, autoraise, autofocus)
yabai -m config focus_follows_mouse off

# modify window shadows (default: on, options: on, off, float)
# example: show shadows only for floating windows
yabai -m config window_shadow float

# window opacity (default: off)
yabai -m config window_opacity on
yabai -m config active_window_opacity 0.98
yabai -m config normal_window_opacity 0.98

# window rules
yabai -m rule --add app="^Zen$" opacity=1.0
yabai -m rule --add app="^Safari$" opacity=1.0
yabai -m rule --add app="^QuickTime Player$" opacity=1.0
yabai -m rule --add app="^Preview$" opacity=1.0

yabai -m rule --add app="^System Settings$" manage=off grid=8:8:2:1:4:6 
yabai -m rule --add sub-role="^AXDialog$" manage=off
yabai -m rule --add title="^Open$" manage=off

yabai -m rule --add app="^Finder$" manage=off grid=6:5:1:1:3:4

yabai -m config window_topmost off
yabai -m rule --add manage=off layer=below
